{
  "name": "shop-management",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main/main.js",
  "scripts": {
    "frontend": "npm --prefix frontend/vite-project run dev",
    "backend": "npm --prefix backend run dev",
    "electron": "electron .",
    "dev": "concurrently -k \"npm run frontend\" \"npm run backend\" \"npm run electron\"",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.shopmanagement.app",
    "productName": "Shop Management",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/vite-project/dist/**/*",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0"
  }
}
