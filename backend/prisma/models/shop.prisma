model Shop {
  id          Int      @id @default(autoincrement())

  name        String
  email       String   @unique
  phone       String?

  address     String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  subscriptions Subscription[]

  @@map("shops")
}