model Subscription {
  id        Int      @id @default(autoincrement())

  shopId    Int
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  planName  String
  amount    Decimal  @db.Decimal(10,2)

  startDate DateTime
  endDate   DateTime

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())

  @@map("subscriptions")
}